<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>RequireReopenReason</fullName>
    <active>false</active>
    <errorConditionFormula>AND(
    ISPICKVAL(Status, &quot;Reopened&quot;),
    ISCHANGED(Status),
    ISPICKVAL(ReopenReason__c, &quot;&quot;)
)</errorConditionFormula>
    <errorMessage>Please select a reopening reason before changing the status to “Reaperturado”.</errorMessage>
</ValidationRule>
